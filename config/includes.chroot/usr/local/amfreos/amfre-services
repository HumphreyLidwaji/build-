#!/bin/bash
# AmfreOS Security Service Manager - Wazuh-Safe Edition

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# Services to manage
SERVICES=("ufw" "fail2ban" "clamav-daemon" "rkhunter" "chkrootkit")

# Default Wazuh ports to allow in firewall
WAZUH_AGENT_PORTS=(1514 55000)
WAZUH_SERVER_IP="127.0.0.1"  # Change if server is remote

check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}This script must be run as root${NC}"
        exit 1
    fi
}

# Show status of all services
show_status() {
    echo -e "${WHITE}Current Service Status:${NC}"
    for service in "${SERVICES[@]}"; do
        if systemctl list-units --type=service | grep -q "$service"; then
            if systemctl is-active "$service" >/dev/null 2>&1; then
                echo -e "${GREEN}$service: Active${NC}"
            else
                echo -e "${YELLOW}$service: Inactive${NC}"
            fi
        else
            echo -e "${RED}$service: Not Installed${NC}"
        fi
    done
}

# Start service
start_service() {
    local service="$1"
    echo -e "${CYAN}Starting $service...${NC}"
    systemctl start "$service"
}

# Stop service
stop_service() {
    local service="$1"
    echo -e "${CYAN}Stopping $service...${NC}"
    systemctl stop "$service"
}

# Restart service
restart_service() {
    local service="$1"
    echo -e "${CYAN}Restarting $service...${NC}"
    systemctl restart "$service"
}

# Install all services
install_services() {
    echo -e "${CYAN}Installing all security services...${NC}"
    apt update
    apt install -y ufw fail2ban clamav clamav-daemon rkhunter chkrootkit mailutils

    # Configure UFW for Wazuh
    echo -e "${CYAN}Configuring UFW to allow Wazuh ports...${NC}"
    for port in "${WAZUH_AGENT_PORTS[@]}"; do
        ufw allow $port/tcp
    done
    ufw --force enable

    # Configure Fail2Ban safe defaults
    echo -e "${CYAN}Excluding Wazuh server from Fail2Ban...${NC}"
    FAIL2BAN_CONF="/etc/fail2ban/jail.local"
    if ! grep -q "ignoreip" "$FAIL2BAN_CONF" 2>/dev/null; then
        echo "ignoreip = 127.0.0.1 $WAZUH_SERVER_IP" >> "$FAIL2BAN_CONF"
    fi
    systemctl enable ufw fail2ban clamav-daemon

    echo -e "${GREEN}All services installed and safely configured for Wazuh.${NC}"
}

# Uninstall services
uninstall_services() {
    echo -e "${YELLOW}Removing all security services...${NC}"
    apt remove --purge -y ufw fail2ban clamav clamav-daemon rkhunter chkrootkit mailutils
    apt autoremove -y
    echo -e "${GREEN}All services removed.${NC}"
}

# Menu
main_menu() {
    check_root
    while true; do
        echo -e "${CYAN}AmfreOS Security Services Manager${NC}"
        echo "1. Show service status"
        echo "2. Start a service"
        echo "3. Stop a service"
        echo "4. Restart a service"
        echo "5. Install all services (Wazuh-safe)"
        echo "6. Uninstall all services"
        echo "7. Exit"
        read -p "Enter your choice: " choice
        case $choice in
            1) show_status ;;
            2)
                read -p "Enter service name: " svc
                start_service "$svc"
                ;;
            3)
                read -p "Enter service name: " svc
                stop_service "$svc"
                ;;
            4)
                read -p "Enter service name: " svc
                restart_service "$svc"
                ;;
            5) install_services ;;
            6) uninstall_services ;;
            7) exit 0 ;;
            *) echo -e "${RED}Invalid choice${NC}" ;;
        esac
        echo
    done
}

main_menu
