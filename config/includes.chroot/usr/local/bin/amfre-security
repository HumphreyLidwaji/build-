#!/bin/bash
# AmfreOS Security Manager - Unified Menu

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

show_banner() {
    clear
    echo -e "${CYAN}"
    echo "╔════════════════════════════════════════╗"
    echo "║          AMFREOS SECURITY MANAGER      ║"
    echo "╚════════════════════════════════════════╝"
    echo -e "${NC}"
}

while true; do
    show_banner
    echo -e "${WHITE}Select an option:${NC}"
    echo -e "1. Deploy Security (Server / Endpoint)"
    echo -e "2. Open Dashboard"
    echo -e "3. Run Self-Healing Now"
    echo -e "4. Apply Security Hardening"
    echo -e "5. Configure Email Alerts"
    echo -e "6. Manage Security Services (ufw, fail2ban, clamav, rkhunter, chkrootkit)"
    echo -e "7. Exit"
    echo

    read -p "Enter choice (1-7): " CHOICE

    case $CHOICE in
        1)
            /usr/local/amfreos/amfre-deploy
            ;;
        2)
            /usr/local/amfreos/amfre-dashboard
            ;;
        3)
            /usr/local/amfreos/amfre-heal
            ;;
        4)
            /usr/local/amfreos/amfre-harden
            ;;
        5)
            /usr/local/amfreos/amfre-email-config
            ;;
        6)
            /usr/local/amfreos/amfre-services
            ;;
        7)
            echo -e "${GREEN}Exiting AmfreOS Security Manager. Stay safe!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid choice. Enter 1-7.${NC}"
            sleep 1
            ;;
    esac

    echo
    read -p "Press Enter to return to main menu..."
done
